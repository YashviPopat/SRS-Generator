flowchart TD
    A[User Device] --> B(User Interface)
    B --> C{Authentication}
    C -->|Valid| D[Dashboard]
    C -->|Invalid| E[Login Page]
    
    D --> F[Learning Module]
    D --> G[Assessment Module]
    D --> H[Progress Tracking]
    
    F --> I[(Content Database)]
    G --> J[(Assessment Database)]
    H --> K[(Analytics Database)]
    
    I --> L[Content Management System]
    J --> M[Assessment Engine]
    K --> N[Analytics Engine]
    
    L --> O[Admin Panel]
    M --> O
    N --> O
    
    %% External Systems
    O --> P[External LMS]
    O --> Q[Reporting System]
    
    %% Styling
    classDef userNodes fill:#e1f5fe
    classDef systemNodes fill:#f3e5f5
    classDef dataNodes fill:#e8f5e8
    classDef externalNodes fill:#fff3e0
    
    class A,B,E userNodes
    class D,F,G,H,L,M,N systemNodes
    class I,J,K dataNodes
    class P,Q,O externalNodes
